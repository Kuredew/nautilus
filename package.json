{
  "name": "Nautilus",
  "type": "module",
  "version": "2.0.0",
  "description": "",
  "main": "src/index.js",
  "watch": {
    "build:dev": {
      "patterns": [
        "src"
      ],
      "extensions": "js",
      "quiet": false
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "watch": "pnpm run prebuild && npm-watch build:dev",
    "compile": "esbuild src/index.ts --bundle --outfile=build/bundle.js --loader:.txt=text --loader:.jsx=text --loader:.png=binary --loader:.ffx=binary & extendscriptr --script build/bundle.js --output dist/Nautilus.jsx",
    "build:dev": "pnpm run compile && pnpm run postbuild",
    "prebuild": "node scripts/preBuild.js",
    "build": "pnpm run compile",
    "postbuild": "node scripts/postBuild.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.0",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "czg": "^1.12.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.0.3",
    "eslint-plugin-import": "^2.32.0",
    "extendscriptr": "^1.2.5",
    "globals": "^17.4.0",
    "npm-watch": "^0.13.0"
  },
  "dependencies": {
    "types-for-adobe": "^7.2.5",
    "typescript": "^7.0.2"
  }
}
